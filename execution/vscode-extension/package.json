{
  "name": "autopm-code-review",
  "displayName": "AutoPM — AI Code Review",
  "description": "Autonomous AI-powered code review, generation, and GitHub integration",
  "version": "1.0.0",
  "publisher": "autopm-team",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autopm.reviewFile",
        "title": "AutoPM: Review This File"
      },
      {
        "command": "autopm.reviewSelection",
        "title": "AutoPM: Review Selected Code"
      },
      {
        "command": "autopm.generateFix",
        "title": "AutoPM: Generate Fix from Issue"
      },
      {
        "command": "autopm.pushToGitHub",
        "title": "AutoPM: Push to GitHub"
      },
      {
        "command": "autopm.runPipeline",
        "title": "AutoPM: Run Full Pipeline"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "autopm.reviewFile",
          "group": "autopm@1",
          "when": "editorTextFocus"
        },
        {
          "command": "autopm.reviewSelection",
          "group": "autopm@2",
          "when": "editorHasSelection"
        }
      ]
    },
    "configuration": {
      "title": "AutoPM",
      "properties": {
        "autopm.serverUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the AutoPM backend server"
        },
        "autopm.autoReviewOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically review files on save"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/assert": "^1.5.11",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.110.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "mocha": "^10.8.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}
